      <title>дёӢиҪҪ Hinata/Sakurazaka 46 Blogеӣҫ</title>
      <link href="2020/12/09/%E7%88%AC%E5%8F%96%E8%93%9D%E7%99%BD%E5%9D%82%E7%9A%84blog%E5%9B%BE/"/>
      <url>2020/12/09/%E7%88%AC%E5%8F%96%E8%93%9D%E7%99%BD%E5%9D%82%E7%9A%84blog%E5%9B%BE/</url>
      
        <content type="html"><![CDATA[<h2 id="еүҚиЁҖ"><a href="#еүҚиЁҖ" class="headerlink" title="еүҚиЁҖ"></a>еүҚиЁҖ</h2><p>зӣ®еүҚеҸҜд»ҘдҪҝз”Ёиҝҷж®өд»Јз ҒзҲ¬еҸ–ж—Ҙеҗ‘еқӮ46пјҲhinatazaka46.comпјүгҖҒжЁұеқӮ46(keyakizaka46.com)зҡ„жҲҗе‘ҳblogеӣҫгҖӮ</p><a id="more"></a><hr><p><strong>жіЁж„Ҹ</strong><br>        д»Јз ҒдёӯжңҖејҖе§Ӣзҡ„вҖңеҲқе§Ӣи®ҫзҪ®вҖқйғЁеҲҶжҳҜйңҖиҰҒдҪҝз”ЁиҖ…иҮӘе®ҡд№үзҡ„пјҢжҜ”еҰӮпјҡи®ҫзҪ®зҲ¬еҸ–зҡ„жҲҗе‘ҳзҡ„еҗҚеӯ—пјҲеҰӮkatoshiгҖҒkosakaзӯүзӯүпјүпјҢиҝҳйңҖиҰҒи®ҫзҪ®urlпјҢиҝҷйңҖиҰҒдҪҝз”ЁиҖ…иҝӣе…Ҙи“қеӣўе®ҳзҪ‘жҲ–иҖ…зҷҪеӣўе®ҳзҪ‘зҡ„жҲҗе‘ҳblogз•ҢйқўеӨҚеҲ¶дёҠж–№зҡ„зҪ‘еқҖе№¶иҙҙеңЁurl = еҗҺйқўпјҢ</p><p>вҖӢ    пјҲPSпјҡз”ұдәҺеҗҢдёҖдёӘжҲҗе‘ҳзҡ„blogжҳҜеҸҜд»Ҙзҝ»йЎөзҡ„пјҢжүҖд»ҘйңҖиҰҒдёҚеҗҢзҡ„йЎөзҡ„urlжқҘиҺ·еҸ–еҜ№еә”йЎөзҡ„еӣҫзүҮпјҢжӯӨж—¶жіЁж„ҸдёҚд»…иҰҒж”№urlеҗҚиҝҳиҰҒж”№nameпјҢеҸҜд»Ҙж”№жҲҗеҰӮkosakaе’Ңkosaka_2_пјү</p><hr><h2 id="ж•Ҳжһңеӣҫ"><a href="#ж•Ҳжһңеӣҫ" class="headerlink" title="ж•Ҳжһңеӣҫ"></a>ж•Ҳжһңеӣҫ</h2><p>иҝҷжҳҜжҲ‘дёӢиҪҪдәҶеҮ дёӘжҲҗе‘ҳд№ӢеҗҺзҡ„зҠ¶жҖҒ<br><img src="https://img-blog.csdnimg.cn/20201122153229172.png?x-oss-process=image/watermark,type_ZmFuZ3poZW5naGVpdGk,shadow_10,text_aHR0cHM6Ly9ibG9nLmNzZG4ubmV0L3dlaXhpbl80MzY2ODU0Ng==,size_16,color_FFFFFF,t_70#pic_center" alt="еңЁиҝҷйҮҢжҸ’е…ҘеӣҫзүҮжҸҸиҝ°"><br>иҝҷе°ұжҳҜжҲ‘дёҠйқўиҜҙзҡ„з”Ёkosaka_2_е‘ҪеҗҚnameзҡ„ж•Ҳжһң<br><img src="https://img-blog.csdnimg.cn/2020112215330447.png?x-oss-process=image/watermark,type_ZmFuZ3poZW5naGVpdGk,shadow_10,text_aHR0cHM6Ly9ibG9nLmNzZG4ubmV0L3dlaXhpbl80MzY2ODU0Ng==,size_16,color_FFFFFF,t_70#pic_center" alt="иҝҷжҳҜkosakaз¬¬дәҢйЎөзҡ„еҶ…е®№"></p><p><strong>д»Јз ҒеҰӮдёӢ</strong></p><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br><span class="line">19</span><br><span class="line">20</span><br><span class="line">21</span><br><span class="line">22</span><br><span class="line">23</span><br><span class="line">24</span><br><span class="line">25</span><br><span class="line">26</span><br><span class="line">27</span><br><span class="line">28</span><br><span class="line">29</span><br><span class="line">30</span><br><span class="line">31</span><br><span class="line">32</span><br><span class="line">33</span><br><span class="line">34</span><br><span class="line">35</span><br><span class="line">36</span><br><span class="line">37</span><br><span class="line">38</span><br><span class="line">39</span><br><span class="line">40</span><br><span class="line">41</span><br><span class="line">42</span><br><span class="line">43</span><br><span class="line">44</span><br><span class="line">45</span><br><span class="line">46</span><br><span class="line">47</span><br><span class="line">48</span><br><span class="line">49</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">import</span> os,sys,time,json,time</span><br><span class="line"><span class="keyword">import</span> socket,random,hashlib</span><br><span class="line"><span class="keyword">from</span> concurrent.futures.process <span class="keyword">import</span> ProcessPoolExecutor</span><br><span class="line"><span class="keyword">import</span> requests,configparser</span><br><span class="line"><span class="keyword">import</span> json,re</span><br><span class="line"></span><br><span class="line"><span class="comment">#еҲқе§Ӣи®ҫзҪ®</span></span><br><span class="line">name = <span class="string">&quot;katoshi&quot;</span> <span class="comment">#жғіиҰҒе°ҶеӣҫзүҮеҸ–зҡ„еҗҚеӯ—</span></span><br><span class="line">os.makedirs(<span class="string">&#x27;./Picture/&#x27;</span>+name, exist_ok=<span class="literal">True</span>)</span><br><span class="line"><span class="comment">#еңЁзӣ®еҪ•дёӢеҲӣе»әдёҖдёӘж–Үд»¶еӨ№з”ЁдәҺдҝқеӯҳеӣҫзүҮпјҢиҝҷйҮҢд»ҘPictureдёәдҫӢеӯҗ</span></span><br><span class="line">url = <span class="string">&quot;https://www.hinatazaka46.com/s/official/diary/member/list?ima=0000&amp;ct=5&quot;</span><span class="comment"># еҠ и—ӨеҸІ</span></span><br><span class="line"><span class="comment">#url = &quot;https://www.keyakizaka46.com/s/k46o/diary/member/list?ima=0000&amp;ct=43&quot;</span></span><br><span class="line"><span class="comment">#и®ҫзҪ®жғіиҰҒзҲ¬еҸ–зҡ„зҪ‘з«ҷзҪ‘еқҖ</span></span><br><span class="line"></span><br><span class="line"></span><br><span class="line">path=os.getcwd()+<span class="string">&#x27;\\Picture\\&#x27;</span>+name+<span class="string">&quot;\\&quot;</span></span><br><span class="line"><span class="function"><span class="keyword">def</span> <span class="title">getpicurl</span>():</span></span><br><span class="line">    jpglist =[]</span><br><span class="line">    <span class="comment">#и®ҫзҪ®urlең°еқҖдёәжғіиҰҒзҲ¬еҸ–зҡ„еӣҫзүҮ</span></span><br><span class="line">    html = requests.get(url).text</span><br><span class="line">    pic_url = re.findall(<span class="string">&#x27;img src=&quot;(.*?)&quot;&#x27;</span>, html, re.S)</span><br><span class="line">    count = <span class="number">0</span></span><br><span class="line">    print(<span class="built_in">len</span>(pic_url))</span><br><span class="line">    <span class="keyword">for</span> key <span class="keyword">in</span> pic_url:</span><br><span class="line">        <span class="keyword">if</span>(<span class="string">&quot;jpg&quot;</span> <span class="keyword">in</span> key):</span><br><span class="line">            jpglist.append(key)</span><br><span class="line">            count=count+<span class="number">1</span></span><br><span class="line">    print(<span class="string">&quot;е…ЁйғЁеј ж•°дёәпјҡ&quot;</span>+<span class="built_in">str</span>(count)+<span class="string">&quot;ејҖе§ӢдёӢиҪҪе–Ҫ&quot;</span>)</span><br><span class="line">    <span class="keyword">return</span> jpglist</span><br><span class="line">    <span class="comment">#жё…жҙ—еҸӘз•ҷдёӢjpgж–Үд»¶url</span></span><br><span class="line"></span><br><span class="line"></span><br><span class="line"><span class="function"><span class="keyword">def</span> <span class="title">download</span>(<span class="params">pic_url</span>):</span></span><br><span class="line">    num=<span class="number">1</span></span><br><span class="line">    <span class="keyword">for</span> i <span class="keyword">in</span> pic_url:</span><br><span class="line">        print(i)</span><br><span class="line">        r = requests.request(<span class="string">&#x27;get&#x27;</span>, i)  <span class="comment"># иҺ·еҸ–зҪ‘йЎө</span></span><br><span class="line"></span><br><span class="line">        <span class="keyword">with</span> <span class="built_in">open</span>(path + name + <span class="built_in">str</span>(num) + <span class="string">&#x27;.jpg&#x27;</span>, <span class="string">&#x27;wb&#x27;</span>) <span class="keyword">as</span> f:  <span class="comment"># жү“ејҖеҶҷе…ҘеҲ°pathи·Ҝеҫ„йҮҢ-дәҢиҝӣеҲ¶ж–Үд»¶пјҢиҝ”еӣһзҡ„еҸҘжҹ„еҗҚдёәf</span></span><br><span class="line">            f.write(r.content)  <span class="comment"># еҫҖfйҮҢеҶҷе…ҘrеҜ№иұЎзҡ„дәҢиҝӣеҲ¶ж–Үд»¶</span></span><br><span class="line">        f.close()</span><br><span class="line"></span><br><span class="line">        print(<span class="string">&quot;дёӢиҪҪз¬¬&quot;</span>+<span class="built_in">str</span>(num)+<span class="string">&quot;еј еӣҫзүҮжҲҗеҠҹпјҒеҪ“еүҚиҝӣеәҰпјҡ&quot;</span>+<span class="built_in">str</span>(num)+<span class="string">&quot;/&quot;</span>+<span class="built_in">str</span>(<span class="built_in">len</span>(pic_url)))</span><br><span class="line">        num = num+<span class="number">1</span></span><br><span class="line"><span class="comment">#main</span></span><br><span class="line">pic_url = getpicurl()</span><br><span class="line">download(pic_url)</span><br><span class="line">print(<span class="built_in">type</span>(pic_url))</span><br><span class="line">print(<span class="string">&quot;дёӢиҪҪе®ҢжҜ•е–ҪпјҢзҘқжӮЁејҖеҝғ&quot;</span>)</span><br></pre></td></tr></table></figure>]]></content>
      
      
